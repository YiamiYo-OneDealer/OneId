{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "docker: start deps",
      "type": "shell",
      "command": "docker compose up -d postgres seq otel-collector",
      "isBackground": false,
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "npm: dev server",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/src/OneId.Web"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "Local:"
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "dotnet: build",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/src/OneId.Server/OneId.Server.csproj",
        "--configuration",
        "Debug"
      ],
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "start: all deps",
      "dependsOn": ["docker: start deps", "npm: dev server", "dotnet: build"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
