{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET: OneId.Server",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/src/OneId.Server/bin/Debug/net10.0/OneId.Server.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/OneId.Server",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:7070;http://localhost:5248"
      }
    },
    {
      "name": "Browser: Frontend",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/src/OneId.Web/src",
      "sourceMapPathOverrides": {
        "/@fs/*": "${workspaceFolder}/*"
      }
    }
  ],
  "compounds": [
    {
      "name": "Full Stack",
      "configurations": [".NET: OneId.Server", "Browser: Frontend"],
      "preLaunchTask": "start: all deps",
      "stopAll": true
    }
  ]
}
