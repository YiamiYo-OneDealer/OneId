@page
@model ClaimsModel

@{
    ViewData["Title"] = "Your Claims";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Your Claims</h4>
    <div class="d-flex gap-2">
        <a asp-page="/Introspection" class="btn btn-outline-secondary btn-sm">🔍 Introspection</a>
        <form method="post" asp-page-handler="Logout">
            <button type="submit" class="btn btn-outline-danger btn-sm">Sign Out</button>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th style="width:30%">Claim Type</th>
                    <th>Value</th>
                    <th class="text-muted small" style="width:25%">Human-Readable</th>
                </tr>
            </thead>
            <tbody class="font-monospace small">
                @foreach (var (name, value) in Model.Claims)
                {
                    var readable = OneId.SampleClient.Helpers.JwtHelper.TryFormatTimestamp(name, value);
                    <tr>
                        <td class="text-primary fw-semibold align-middle">@name</td>
                        <td class="align-middle text-break">@value</td>
                        <td class="text-muted align-middle small">@readable</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<details class="mt-3">
    <summary class="small text-muted">Raw access token</summary>
    <pre class="json-output small mt-2">@Model.RawToken</pre>
</details>
