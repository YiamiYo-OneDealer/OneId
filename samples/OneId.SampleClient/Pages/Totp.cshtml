@page
@model TotpModel

@{
    ViewData["Title"] = Model.EnrollmentUri is not null ? "Enroll Authenticator" : "Two-Factor Authentication";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body p-4">

                @if (Model.EnrollmentUri is not null)
                {
                    <h4 class="card-title mb-1">Set Up Your Authenticator</h4>
                    <p class="text-muted small mb-3">Scan the QR code with any TOTP app (Google Authenticator, Authy, etc.), then enter the 6-digit code below.</p>

                    <div class="text-center mb-3">
                        <canvas id="qr-canvas"></canvas>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small text-muted">Or copy the setup URI manually</label>
                        <input type="text" class="form-control form-control-sm font-monospace"
                               value="@Model.EnrollmentUri" readonly onclick="this.select()" />
                    </div>
                }
                else
                {
                    <h4 class="card-title mb-1">Two-Factor Authentication</h4>
                    <p class="text-muted small mb-3">Enter the 6-digit code from your authenticator app.</p>
                }

                @if (Model.ErrorMessage is not null)
                {
                    <div class="alert alert-danger">@Model.ErrorMessage</div>
                }

                <form method="post">
                    <div class="mb-3">
                        <label asp-for="Code" class="form-label">Authenticator Code</label>
                        <input asp-for="Code" class="form-control font-monospace text-center fs-4 letter-spacing-wide"
                               type="text" inputmode="numeric" pattern="[0-9]{6}"
                               maxlength="6" autocomplete="one-time-code" placeholder="000000" required />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Verify</button>
                </form>

            </div>
        </div>

        <div class="mt-2 text-center small">
            <a asp-page="/Login">← Back to Sign In</a>
        </div>
    </div>
</div>

@if (Model.EnrollmentUri is not null)
{
    @section Scripts {
        <script src="https://cdn.jsdelivr.net/npm/qrcode@1.5.3/build/qrcode.min.js"></script>
        <script>
            QRCode.toCanvas(
                document.getElementById('qr-canvas'),
                '@Html.Raw(Model.EnrollmentUri)',
                { width: 220 },
                function (err) { if (err) console.error(err); }
            );
        </script>
    }
}
